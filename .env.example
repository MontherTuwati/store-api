PORT=3000

# Used in npm test summary line (assignment format)
STUDENT_EMAIL=you@yourcollege.edu

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/monther-store?retryWrites=true&w=majority

# Team member product JSON endpoints (Maya’s human-readable page is /products-view; use /products for JSON)
JUAN_PRODUCTS_URL=https://juan-store-api.onrender.com/products
MAYA_PRODUCTS_URL=https://mayada-store-api-2.onrender.com/products

# Render free tier can need a long first byte; increase if /products/all-stores times out
REMOTE_FETCH_TIMEOUT_MS=60000
